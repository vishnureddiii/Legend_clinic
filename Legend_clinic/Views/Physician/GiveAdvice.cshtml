@{
    Layout = "~/Views/Shared/_LayoutPhysician.cshtml";
    ViewData["Title"] = "Add Advice & Prescription";
}

<h2 class="text-primary mb-4">Doctor Advice & Prescription</h2>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">
        @ViewBag.Error
    </div>
}

<form asp-action="GiveAdvice" method="post">
    @Html.AntiForgeryToken()

    <!-- Hidden Appointment Id -->
    <input type="hidden" name="appointmentId" value="@ViewBag.AppointmentId" />

    <!-- Doctor Advice -->
    <div class="mb-4">
        <label class="form-label fw-bold">Doctor Advice</label>

        <textarea name="advice"
                  class="form-control"
                  rows="5"
                  required
                  placeholder="Enter doctor advice"></textarea>
    </div>

    <!-- Medicines Section -->
    <h5 class="text-success mb-3">Medicines</h5>

    <div id="prescriptionContainer">

        <!-- First Row -->
        <div class="row prescriptionRow mb-3">

            <!-- Medicine Dropdown -->
            <div class="col-md-5">
                <label class="form-label">Medicine</label>

                <select name="drugIds" class="form-select" required>
                    <option value="">-- Select Medicine --</option>

                    @if (ViewBag.Drugs != null && ViewBag.Drugs.Count > 0)
                    {
                        foreach (var drug in ViewBag.Drugs)
                        {
                            <option value="@drug.DrugId">
                                @drug.Title (@drug.Dosage)
                            </option>
                        }
                    }
                    else
                    {
                        <option disabled>No medicines available</option>
                    }
                </select>
            </div>

            <!-- Prescription Input -->
            <div class="col-md-5">
                <label class="form-label">Prescription</label>

                <input type="text"
                       name="prescriptions"
                       class="form-control"
                       placeholder="Ex: 1 tablet twice daily"
                       required />
            </div>

            <!-- Remove Button -->
            <div class="col-md-2 d-flex align-items-end">
                <button type="button"
                        class="btn btn-danger w-100"
                        onclick="removeRow(this)">
                    Remove
                </button>
            </div>

        </div>

    </div>

    <!-- Add More Button -->
    <button type="button"
            class="btn btn-outline-primary mb-3"
            onclick="addPrescriptionRow()">
        + Add More Medicine
    </button>

    <br />

    <!-- Submit -->
    <button type="submit" class="btn btn-success px-4">
        Send Prescription
    </button>

    <!-- Back -->
    <a asp-action="ViewAppointments" class="btn btn-secondary px-4">
        Back
    </a>

</form>

@section Scripts {
    <script>
        function addPrescriptionRow() {
            let container = document.getElementById("prescriptionContainer");
            let row = document.querySelector(".prescriptionRow");
            let clone = row.cloneNode(true);

            // Clear inputs
            clone.querySelectorAll("input").forEach(input => input.value = "");
            clone.querySelectorAll("select").forEach(select => select.selectedIndex = 0);

            container.appendChild(clone);
        }

        function removeRow(button) {
            let rows = document.querySelectorAll(".prescriptionRow");

            if (rows.length > 1) {
                button.closest(".prescriptionRow").remove();
            }
        }
    </script>
}