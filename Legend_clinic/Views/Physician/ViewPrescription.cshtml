@model IEnumerable<Legend_clinic.Models.PhysicianAdvice>

@{
    Layout = "~/Views/Shared/_LayoutPhysician.cshtml";
}

<h3 class="text-primary mb-4">📄 Prescription Details</h3>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-warning">
        No prescription found.
    </div>
}
else
{
    @foreach (var advice in Model)
    {
        <div class="card shadow-sm mb-4">
            <div class="card-body">

                <h5 class="text-success">Doctor Advice</h5>
                <p>@advice.Advice</p>

                <h6 class="mt-3">Medicines</h6>

                <div class="table-responsive">
                    <table class="table table-bordered mt-2">
                        <thead class="table-light">
                            <tr>
                                <th>Drug</th>
                                <th>Dosage</th>
                                <th>Instruction</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var p in advice.PhysicianPrescriptions)
                            {
                                <tr>
                                    <td>@p.Drug?.Title</td>
                                    <td>@p.Drug?.Dosage</td>
                                    <td>@p.Prescription</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

            </div>
        </div>
    }
}

<a asp-action="ViewAppointments" class="btn btn-secondary">
    ← Back to Appointments
</a>