@model IEnumerable<Legend_clinic.Models.Appointment>

@{
    Layout = "~/Views/Shared/_LayoutPhysician.cshtml";
    ViewData["Title"] = "My Appointments";

    var todayList = ViewBag.TodayAppointments as List<Legend_clinic.Models.Appointment>;
    var upcomingList = ViewBag.UpcomingAppointments as List<Legend_clinic.Models.Appointment>;
    var completedList = ViewBag.CompletedAppointments as List<Legend_clinic.Models.Appointment>;
}

<h2 class="mb-4">My Appointments</h2>

<!-- ================= TABS ================= -->
<ul class="nav nav-tabs mb-3" id="appointmentTabs" role="tablist">

    <li class="nav-item">
        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#todayTab">
            📅 Today
        </button>
    </li>

    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#upcomingTab">
            ⏳ Upcoming
        </button>
    </li>

    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#completedTab">
            ✅ Completed
        </button>
    </li>

</ul>

<!-- ================= TAB CONTENT ================= -->
<div class="tab-content">

    <!-- TODAY -->
    <div class="tab-pane fade show active" id="todayTab">
        @Html.Partial("_AppointmentTable", todayList)
    </div>

    <!-- UPCOMING -->
    <div class="tab-pane fade" id="upcomingTab">
        @Html.Partial("_AppointmentTable", upcomingList)
    </div>

    <!-- COMPLETED -->
    <div class="tab-pane fade" id="completedTab">
        @Html.Partial("_AppointmentTable", completedList)
    </div>

</div>