@model IEnumerable<Legend_clinic.Models.Appointment>

@{
    Layout = "~/Views/Shared/_LayoutPhysician.cshtml";
    ViewData["Title"] = "My Appointments";
}

<h2 class="mb-4">My Appointments</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<table class="table table-bordered table-hover">
    <thead class="table-primary">
        <tr>
            <th>Patient</th>
            <th>Date</th>
            <th>Reason</th>
            <th>Status</th>
            <th>Consultation</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Patient?.Name</td>

                <!-- ✅ FORMAT DATE PROPERLY -->
                <td>@item.AppointmentDateTime.ToString("dd-MM-yyyy hh:mm tt")</td>

                <td>@item.Reason</td>

                <!-- ✅ SAFE STATUS -->
                <td>@(item.Schedules?.FirstOrDefault()?.ScheduleStatus ?? "Pending")</td>

                <td>
                    @if (item.Schedules != null &&
                                             item.Schedules.Any(s => s.PhysicianAdvices.Any()))
                    {
                        <!-- ✅ VIEW BUTTON -->
                        <a asp-action="ViewPrescription"
                               asp-route-appointmentId="@item.AppointmentId"
                               class="btn btn-info btn-sm">
                            View Prescription
                        </a>
                    }
                    else
                    {
                        <!-- ✅ ADD BUTTON -->
                        <a asp-action="GiveAdvice"
                               asp-route-appointmentId="@item.AppointmentId"
                               class="btn btn-success btn-sm">
                            Add Prescription
                        </a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>