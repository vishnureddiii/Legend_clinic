@model Legend_clinic.Models.Appointment
@{
    Layout = "_PatientLayout";
    ViewData["Title"] = "Book Appointment";
}

<h2>Book Appointment</h2>

<!-- BACK BUTTON FIXED -->
<a asp-controller="Home" asp-action="PatientDashboard" class="btn btn-secondary mb-3">
    ⬅ Back
</a>

<form asp-action="BookAppointment" method="post">

    <!-- DOCTOR -->
    <div class="mb-3">
        <label>Doctor</label>
        <div class="mb-3">
            <label>Doctor</label>
            <input class="form-control" value="Assigned by Admin" disabled />
        </div>
    </div>

    <!-- DATE -->
    <div class="mb-3">
        <label>Date & Time</label>
        <input asp-for="AppointmentDateTime"
               type="datetime-local"
               class="form-control"
               id="apptDate"
               required />
    </div>

    <!-- CRITICALITY -->
    <div class="mb-3">
        <label>Criticality</label>
        <select asp-for="Criticality" class="form-control" required>
            <option value="">-- Select --</option>
            <option value="Low">Emergency</option>
            <option value="Medium">Normal</option>
            <option value="High">Medium</option>
        </select>
    </div>

    <!-- REASON -->
    <div class="mb-3">
        <label>Reason</label>
        <input asp-for="Reason" class="form-control" required />
    </div>

    <!-- NOTE -->
    <div class="mb-3">
        <label>Note</label>
        <input asp-for="Note" class="form-control" required />
    </div>

    <button type="submit" class="btn btn-success">Book</button>

</form>

<!-- ✅ BLOCK PAST + CURRENT DATE -->
<script>
    const now = new Date();
    const minDateTime = new Date(now.getTime() + 60000) // +1 minute buffer

    const formatted = minDateTime.toISOString().slice(0, 16);
    document.getElementById("apptDate").min = formatted;
</script>