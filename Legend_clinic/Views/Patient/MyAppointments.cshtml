@model List<Legend_clinic.Models.Appointment>

@{
    Layout = "_PatientLayout";
    ViewData["Title"] = "My Appointments";
}

<h2>My Appointments</h2>

<a asp-controller="Home" asp-action="PatientDashboard" class="btn btn-secondary mb-3">
    ⬅ Back
</a>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>Doctor</th>
            <th>Date & Time</th>
            <th>Reason</th>
            <th>Status</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>

                <!-- DOCTOR (SAFE NULL CHECK) -->
                <td>
                    @if (item.Physician != null)
                    {
                        <span>@item.Physician.Name</span>
                    }
                    else
                    {
                        <span class="text-muted">Not Assigned</span>
                    }
                </td>

                <!-- DATE -->
                <td>
                    @item.AppointmentDateTime.ToString("dd-MM-yyyy hh:mm tt")
                </td>

                <!-- REASON -->
                <td>
                    @item.Reason
                </td>

                <!-- STATUS -->
                <td>
                    <span class="badge
                        @(item.ScheduleStatus == "Approved" ? "bg-success" :
                                                    item.ScheduleStatus == "Rejected" ? "bg-danger" :
                                                    "bg-warning")">
                        @item.ScheduleStatus
                    </span>
                </td>

            </tr>
        }
    </tbody>
</table>