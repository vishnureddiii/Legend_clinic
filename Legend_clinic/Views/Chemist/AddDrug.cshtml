@model Legend_clinic.Models.Drug

@{
    ViewData["Title"] = "Add Drug";
    Layout = "~/Views/Shared/_LayoutChemist.cshtml";
}

<div class="container mt-4">

    <!-- BACK BUTTON -->
    <a asp-action="Index" class="btn btn-secondary mb-3">
        ⬅ Back to Dashboard
    </a>

    <div class="card shadow">
        <div class="card-header bg-success text-white">
            <h4>💊 Add New Drug</h4>
        </div>

        <div class="card-body">

            <!-- FORM -->
            <form asp-action="AddDrug" method="post" id="drugForm">

                <div class="mb-3">
                    <label class="form-label">Drug Title</label>
                    <input asp-for="Title" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <input asp-for="Description" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Dosage</label>
                    <input asp-for="Dosage" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Expiry</label>
                    <input asp-for="Expiry"
                           type="date"
                           class="form-control"
                           id="expiryDate" />
                </div>

                <button class="btn btn-success">Save Drug</button>

            </form>

        </div>
    </div>

</div>

<!-- VALIDATION SCRIPT -->
@section Scripts {
    <script>
        document.getElementById("drugForm").addEventListener("submit", function (e) {

            let expiryValue = document.getElementById("expiryDate").value;

            if (expiryValue) {

                let selectedDate = new Date(expiryValue);

                // remove time part
                selectedDate.setHours(0, 0, 0, 0);

                let today = new Date();
                today.setHours(0, 0, 0, 0);

                // ❌ invalid if past date
                if (selectedDate < today) {
                    e.preventDefault();
                    alert("❌ Invalid date! Expiry must be today or a future date.");
                }
            }

        });
    </script>
}