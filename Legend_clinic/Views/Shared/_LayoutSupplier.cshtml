<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Supplier Panel</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

</head>
<body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/Supplier/Index">Supplier Panel</a>

            <div class="collapse navbar-collapse">
                <ul class="navbar-nav me-auto">

                  @*   <li class="nav-item">
                        <a class="nav-link" href="/Supplier/Index">Dashboard</a>
                    </li> *@

                 

                    <li class="nav-item">
                        <a asp-controller="Supplier" asp-action="DrugRequests" class="nav-link">
