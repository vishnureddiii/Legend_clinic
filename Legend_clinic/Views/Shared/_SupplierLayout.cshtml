<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Supplier Panel</title>

    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
            body {
                margin: 0;
                background: #f4f7ff;
                font-family: 'Segoe UI', sans-serif;
            }

            .topbar {
                height: 60px;
                background: linear-gradient(135deg, #0b5ed7, #0dcaf0);
                color: white;
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 0 20px;
                position: fixed;
                width: 100%;
                top: 0;
                z-index: 1000;
            }

            .sidebar {
                position: fixed;
                top: 60px;
                left: 0;
                width: 220px;
                height: 100vh;
                background: #0b5ed7;
                padding: 15px;
            }

                .sidebar a {
                    display: block;
                    color: white;
                    padding: 12px;
                    text-decoration: none;
                    margin-bottom: 8px;
                    border-radius: 6px;
                }

                    .sidebar a:hover {
                        background: rgba(255,255,255,0.2);
                    }

            .content {
                margin-left: 220px;
                margin-top: 60px;
                padding: 20px;
            }
    </style>
</head>

<body>

    <!-- TOP BAR -->
    <div class="topbar">
        <div><b>Supplier Panel</b></div>

        <div>
            👤 @Context.Session.GetString("UserName")
            <a class="btn btn-sm btn-danger ms-3"
                   asp-controller="Account"
                   asp-action="Logout">
                Logout
            </a>
        </div>
    </div>

    <!-- SIDEBAR -->
    <div class="sidebar">

        <a asp-controller="Supplier" asp-action="Orders">
            📦 Purchase Orders
        </a>

    </div>

    <!-- CONTENT -->
    <div class="content">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>