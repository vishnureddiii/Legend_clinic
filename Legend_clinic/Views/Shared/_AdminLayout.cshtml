<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Admin</title>

    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body>

    
    <nav class="navbar navbar-dark bg-dark">
        <div class="container-fluid">
            <span class="navbar-brand">Clinic Admin</span>

            <div>
                <span class="text-white me-3">
                    @Context.Session.GetString("UserName")
                </span>

                <a class="btn btn-danger btn-sm" asp-controller="Account" asp-action="Logout">
                    Logout
                </a>
            </div>
        </div>
    </nav>

    
    <div class="container mt-4">
        <div class="row">

            
            <div class="col-md-3">
                <div class="list-group">

                    <a asp-controller="Home" asp-action="AdminDashboard" class="list-group-item">
                        Dashboard
                    </a>

                    <a asp-controller="Admin" asp-action="CreateUser" class="list-group-item">
                        Create User
                    </a>

                    <a asp-controller="Admin" asp-action="ManagePhysicians" class="list-group-item">
                        Manage Physicians
                    </a>

                    <a asp-controller="Admin" asp-action="ManageChemists" class="list-group-item">
                        Manage Chemists
                    </a>

                    <a asp-controller="Admin" asp-action="ManageSuppliers" class="list-group-item">
                        Manage Suppliers
                    </a>

                    <a asp-controller="Admin" asp-action="PendingAppointments" class="list-group-item">
                        Manage Appointments
                    </a>

                    <a asp-controller="Admin" asp-action="PendingPatients" class="list-group-item">
                        Pending Patients
                    </a>

                </div>
            </div>
            
            <div class="col-md-9">
                @RenderBody()
            </div>

        </div>
    </div>

    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    
    @RenderSection("Scripts", required: false)

</body>
</html>