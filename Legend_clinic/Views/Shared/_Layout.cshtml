<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Clinic System</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
            body {
                margin: 0;
                font-family: 'Segoe UI', sans-serif;
                background: #f6f9ff;
            }

            /* NAVBAR */
            .navbar {
                position: fixed;
                top: 0;
                width: 100%;
                height: 70px;
                background: #0b5ed7;
                display: flex;
                align-items: center;
                z-index: 1000;
            }

                .navbar .nav-link,
                .navbar .navbar-brand {
                    color: white !important;
                }

                    .navbar .nav-link:hover {
                        color: #cfe2ff !important;
                    }

            /* PAGE BELOW NAVBAR */
            .page-content {
                margin-top: 90px;
            }

            footer {
                background: #0b5ed7;
            }
    </style>
</head>

<body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container">

            <a class="navbar-brand fw-bold" href="/">🏥 Legend Clinic</a>

            <div class="collapse navbar-collapse justify-content-end">
                <ul class="navbar-nav">

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Drug" asp-action="Index">Drug Info</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Account" asp-action="Register">Register</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Account" asp-action="Login">Login</a>
                    </li>

                </ul>
            </div>

        </div>
    </nav>

    <!-- PAGE CONTENT -->
    <div class="container page-content">
        @RenderBody()
    </div>

    <!-- FOOTER -->
    <footer class="text-white text-center py-3 mt-5">
        <p class="mb-0">&copy; @DateTime.Now.Year Legend Clinic</p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>