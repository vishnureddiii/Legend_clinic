<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Physician Panel</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="bg-light">

    <div class="container-fluid">
        <div class="row min-vh-100">

            <!-- Sidebar -->
            <div class="col-md-3 col-lg-2 bg-primary text-white p-4">
                <h4 class="mb-4">Doctor Panel</h4>

                <div class="nav flex-column">

                    <a asp-controller="Physician"
                           asp-action="Dashboard"
                           class="btn btn-primary text-start mb-2 border">
                        Dashboard
                    </a>

                    <a asp-controller="Physician"
                           asp-action="ViewAppointments"
                           class="btn btn-primary text-start mb-2 border">
                        Appointments
                    </a>

                    <!-- Advice + Prescription Combined -->
                    <a asp-controller="Physician"
                           asp-action="GiveAdvice"
                           class="btn btn-primary text-start mb-2 border">
                        Give Advice & Prescription
                    </a>

                    <a asp-controller="Physician"
                           asp-action="DrugRequest"
                           class="btn btn-primary text-start mb-2 border">
                        Drug Request
                    </a>

                    <a asp-controller="Account"
                           asp-action="Logout"
                           class="btn btn-danger text-start mt-4">
                        Logout
                    </a>

                </div>
            </div>

            <!-- Main Content -->
            <div class="col-md-9 col-lg-10 p-4">

                <!-- Topbar -->
                <div class="card shadow-sm mb-4">
                    <div class="card-body">
                        <h3 class="text-primary mb-0">
                            @ViewData["Title"]
                        </h3>
                    </div>
                </div>

                <!-- Body -->
                <div class="card shadow-sm">
                    <div class="card-body">

                        @if (ViewBag.Error != null)
                        {
                            <div class="alert alert-danger">
                                @ViewBag.Error
                            </div>
                        }

                        @RenderBody()

                    </div>
                </div>

            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function addPrescriptionRow() {
        let container = document.getElementById("prescriptionContainer");
        if (!container) return;

        let firstRow = document.querySelector(".prescriptionRow");
        if (!firstRow) return;

        let clone = firstRow.cloneNode(true);

        clone.querySelectorAll("input").forEach(input => input.value = "");
        clone.querySelectorAll("select").forEach(select => select.selectedIndex = 0);

        container.appendChild(clone);
        }
         
        function removeRow(button) {
        let rows = document.querySelectorAll(".prescriptionRow");

        if (rows.length > 1) {
        button.closest(".prescriptionRow").remove();
        }
        }
    </script>

    @RenderSection("Scripts", required: false)

</body>
</html>