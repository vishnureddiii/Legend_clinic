
@{
    ViewData["Title"] = "ManageSuppliers";
}



@model IEnumerable<Legend_clinic.Models.Supplier>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Manage Suppliers";
}

<h2>Manage Suppliers</h2>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var supplier in Model)
        {
            <tr>
                <td>@supplier.Name</td>
                <td>@supplier.Email</td>
                <td>@supplier.Phone</td>
                <td>
                    <a asp-action="EditSupplier" asp-route-id="@supplier.SupplierId" class="btn btn-sm btn-primary">Edit</a>
                    <a asp-action="DeleteSupplier" asp-route-id="@supplier.SupplierId" class="btn btn-sm btn-danger"
                       onclick="return confirm('Are you sure you want to delete this supplier?');">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
