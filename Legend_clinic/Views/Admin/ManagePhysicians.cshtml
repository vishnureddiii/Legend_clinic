
@{
    ViewData["Title"] = "ManagePhysicians";
}



@model IEnumerable<Legend_clinic.Models.Physician>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Manage Physicians";
}

<h2>Manage Physicians</h2>
<a asp-controller="Home" asp-action="AdminDashboard"
       class="btn btn-outline-primary mb-3">
    ← Back to Home
</a>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Specialization</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var doctor in Model)
        {
            <tr>
                <td>@doctor.Name</td>
                <td>@doctor.Specialization</td>
                <td>@doctor.Email</td>
                <td>@doctor.Phone</td>
                <td>
                    <a asp-action="EditPhysician" asp-route-id="@doctor.PhysicianId" class="btn btn-sm btn-primary">Edit</a>
                   @*  <a asp-action="DeletePhysician" asp-route-id="@doctor.PhysicianId" class="btn btn-sm btn-danger"
                       onclick="return confirm('Are you sure you want to delete this physician?');">Delete</a> *@
                </td>
            </tr>
        }
    </tbody>
</table>

