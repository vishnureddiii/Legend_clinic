
@{
    ViewData["Title"] = "ManageChemists";
}



@model IEnumerable<Legend_clinic.Models.Chemist>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Manage Chemists";
}

<h2>Manage Chemists</h2>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var chemist in Model)
        {
            <tr>
                <td>@chemist.Name</td>
                <td>@chemist.Email</td>
                <td>@chemist.Phone</td>
                <td>
                    <a asp-action="EditChemist" asp-route-id="@chemist.ChemistId" class="btn btn-sm btn-primary">Edit</a>
                    <a asp-action="DeleteChemist" asp-route-id="@chemist.ChemistId" class="btn btn-sm btn-danger"
                       onclick="return confirm('Are you sure you want to delete this chemist?');">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>