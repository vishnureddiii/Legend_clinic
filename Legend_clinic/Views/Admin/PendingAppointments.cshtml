@model List<Legend_clinic.Models.Appointment>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Pending Appointments";
}

<a asp-controller="Home" asp-action="AdminDashboard"
       class="btn btn-outline-primary mb-3">
    ← Back to Home
</a>

<h2>Pending Appointments</h2>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>Patient</th>
            <th>Date</th>
            <th>Reason</th>
            <th>Criticality</th>
            <th>Assign Doctor & Action</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Patient?.Name</td>
                <td>@item.AppointmentDateTime</td>
                <td>@item.Reason</td>
                <td>@item.Criticality</td>

                <td>
                    <!-- APPROVE FORM -->
                    <form asp-action="ApproveAppointment" method="post" class="mb-2">

                        <input type="hidden" name="id" value="@item.AppointmentId" />

                        <select name="physicianId" class="form-control mb-2" required>
                            <option value="">-- Assign Doctor --</option>
                            @foreach (var doc in ViewBag.Doctors)
                            {
                                <option value="@doc.PhysicianId">
                                    @doc.Name
                                </option>
                            }
                        </select>

                        <button type="submit" class="btn btn-success btn-sm w-100">
                            Approve
                        </button>
                    </form>

                    <!-- REJECT BUTTON -->
                    <a asp-action="RejectAppointment"
                           asp-route-id="@item.AppointmentId"
                           class="btn btn-danger btn-sm w-100">
                        Reject
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>