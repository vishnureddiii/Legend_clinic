@model Legend_clinic.Models.Drug

@{
    ViewData["Title"] = "Drug Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">

    <div class="card p-4 shadow-sm">

        <h3 class="text-primary">@Model.Title</h3>

        <hr />

        <p><strong>Description:</strong> @Model.Description</p>

        <p><strong>Dosage:</strong> @Model.Dosage</p>

        <p><strong>Expiry Date:</strong> @Model.Expiry</p>

        <a asp-action="Index" class="btn btn-secondary mt-3">
            ⬅ Back
        </a>

    </div>

</div>